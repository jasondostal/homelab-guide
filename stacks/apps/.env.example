# Apps Stack Environment Variables
# =================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── General ──────────────────────────────────────────────────
# Timezone for all containers (e.g., America/New_York, Europe/London)
TZ=America/Chicago

# User/group IDs for file permissions (run `id` to find yours).
# LinuxServer.io containers use these to set ownership of config files.
PUID=1000
PGID=1000

# ── Domain ───────────────────────────────────────────────────
# Your base domain for SWAG reverse proxy routing.
DOMAIN=yourdomain.com

# ── Jellyfin ─────────────────────────────────────────────────
# Image version tag. "latest" tracks the current stable release.
# Pin to a specific version (e.g., 10.9.6) for predictable upgrades.
JELLYFIN_VERSION=latest

# Port for direct access (before SWAG is set up).
JELLYFIN_PORT=8096

# Subdomain for SWAG routing (result: https://jellyfin.yourdomain.com)
JELLYFIN_SUBDOMAIN=jellyfin

# Media library paths on the host.
# These are mounted read-only into the container.
# Adjust to match your actual storage layout.
MEDIA_MOVIES_PATH=/mnt/media/movies
MEDIA_TV_PATH=/mnt/media/tv
MEDIA_MUSIC_PATH=/mnt/media/music

# Resource limits. Increase if you have heavy transcoding needs
# or many simultaneous streams.
JELLYFIN_CPU_LIMIT=4.0
JELLYFIN_MEM_LIMIT=2G

# ── Vaultwarden ──────────────────────────────────────────────
# Image version tag. "latest" is fine — Vaultwarden releases are stable.
VAULTWARDEN_VERSION=latest

# Port for direct access (disabled by default in compose — uncomment
# the ports section there if you need it for initial setup).
VAULTWARDEN_PORT=8080

# Subdomain for SWAG routing (result: https://vault.yourdomain.com)
VAULTWARDEN_SUBDOMAIN=vault

# Allow new user signups. Set to "true" for initial setup,
# then change to "false" after creating your account.
VAULTWARDEN_SIGNUPS=false

# Admin panel token. Generate with: openssl rand -base64 48
# Leave empty to disable the admin panel entirely.
# The admin panel is at https://vault.yourdomain.com/admin
VAULTWARDEN_ADMIN_TOKEN=

# ── Homepage ─────────────────────────────────────────────────
# Image version tag.
HOMEPAGE_VERSION=latest

# Port for direct access.
HOMEPAGE_PORT=3000

# Subdomain for SWAG routing (result: https://home.yourdomain.com)
HOMEPAGE_SUBDOMAIN=home
