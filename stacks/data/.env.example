# Data Stack Environment Variables
# =================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Use strong, unique passwords. Generate them with:
#   openssl rand -base64 32

# ── System ─────────────────────────────────────────────────
TZ=America/Chicago

# ── PostgreSQL ─────────────────────────────────────────────
# Image version tag (e.g., pg16, pg15). This uses pgvector/pgvector
# which bundles the pgvector extension with official Postgres.
POSTGRES_VERSION=pg16

# Database superuser credentials.
# Change these BEFORE first boot — they're baked into the data volume.
POSTGRES_USER=homelab_admin
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Default database created on first boot.
POSTGRES_DB=homelab

# Host port mapping. Change if 5432 conflicts with a host Postgres.
POSTGRES_PORT=5432

# Shared memory size for Postgres. Increase for complex queries
# or many concurrent connections.
POSTGRES_SHM_SIZE=256m

# ── Redis ──────────────────────────────────────────────────
# Image version tag (e.g., 7-alpine, 7, 6-alpine).
# Alpine variants are smaller (~30MB vs ~130MB).
REDIS_VERSION=7-alpine

# Redis authentication password.
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Host port mapping.
REDIS_PORT=6379

# Maximum memory Redis will use before evicting keys.
# Rule of thumb: set this to ~50% of your container memory limit.
REDIS_MAXMEMORY=256mb
