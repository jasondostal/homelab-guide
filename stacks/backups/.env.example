# Backup Environment Variables
# ============================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These variables are sourced by the backup scripts in ../scripts/.
# They are NOT used by Docker Compose (this stack has no containers).
#
# IMPORTANT: Use strong passwords and keep this file secure.
#   chmod 600 .env

# ── Restic Repository ─────────────────────────────────────
# Where backups are stored. Restic supports many backends:
#   Local:  /mnt/backup-drive/restic-repo
#   S3:     s3:s3.amazonaws.com/your-bucket-name
#   B2:     b2:your-bucket-name
#   SFTP:   sftp:user@host:/path/to/repo
#   Rest:   rest:http://host:8000/
RESTIC_REPOSITORY=s3:s3.amazonaws.com/YOUR-BUCKET-NAME

# Restic encryption password. This encrypts all backup data.
# CRITICAL: If you lose this password, your backups are unrecoverable.
# Store it somewhere safe outside your homelab (password manager, etc.)
RESTIC_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── S3-Compatible Storage Credentials ─────────────────────
# Used for S3, B2, Wasabi, MinIO, etc.
# For Backblaze B2: use your B2 application key ID and key.
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY

# ── Backup Sources ─────────────────────────────────────────
# Comma-separated list of directories to back up.
# Docker volumes are typically at /var/lib/docker/volumes/.
BACKUP_PATHS=/var/lib/docker/volumes,/home/deploy/stacks,/etc/docker

# Comma-separated list of containers to stop before backup.
# Databases should be stopped (or dumped) to ensure consistent backups.
# Leave empty to skip stopping containers.
BACKUP_STOP_CONTAINERS=postgres,redis

# ── Retention Policy ──────────────────────────────────────
# How many snapshots to keep. Restic's "forget" command uses these
# to prune old backups. The most specific match wins.
RETENTION_HOURLY=0
RETENTION_DAILY=7
RETENTION_WEEKLY=4
RETENTION_MONTHLY=6
RETENTION_YEARLY=2

# ── Healthchecks.io ───────────────────────────────────────
# Ping URLs for monitoring backup status.
# Create checks at https://healthchecks.io (free tier: 20 checks).
# The backup script pings /start before running, the check URL on
# success, and /fail on error.
HC_PING_BACKUP=https://hc-ping.com/YOUR-UUID-HERE
HC_PING_RESTORE_TEST=https://hc-ping.com/YOUR-UUID-HERE
