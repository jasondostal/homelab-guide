# DNS Stack Environment Variables
# ================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── General ──────────────────────────────────────────────────
# Timezone (e.g., America/New_York, Europe/London)
TZ=America/Chicago

# ── AdGuard Home ─────────────────────────────────────────────
# Image version tag. "latest" tracks current stable.
# Pin to a specific version (e.g., v0.107.52) for predictable upgrades.
ADGUARD_VERSION=latest

# Bind address for DNS. Default 0.0.0.0 listens on all interfaces.
# Set to your server's specific IP if you want to restrict access.
ADGUARD_DNS_HOST=0.0.0.0

# Setup wizard port (first run only).
# After initial setup, this port is no longer used.
ADGUARD_SETUP_PORT=3000

# Admin UI port (day-to-day management).
# This maps to port 80 inside the container, which is where AdGuard
# serves its web UI after the setup wizard completes.
ADGUARD_ADMIN_PORT=8080
