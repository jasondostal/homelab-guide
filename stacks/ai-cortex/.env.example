# AI Cortex Stack Environment Variables
# ======================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── System ─────────────────────────────────────────────────
TZ=America/Chicago

# ── Domain ─────────────────────────────────────────────────
# Base domain for SWAG reverse proxy routing.
# Remove if the cortex box doesn't use SWAG.
DOMAIN=yourdomain.com

# ── Ollama ─────────────────────────────────────────────────
# Image version tag (e.g., latest, 0.3).
OLLAMA_VERSION=latest

# Host port for the Ollama API.
# Other tools (VS Code extensions, CLI scripts) can hit this directly.
OLLAMA_PORT=11434

# Number of inference requests to process in parallel.
# Higher values use more VRAM. Start with 1 and increase if needed.
OLLAMA_NUM_PARALLEL=1

# Resource limits for the Ollama container.
# Memory should be enough for your largest model + overhead.
# A 7B model needs ~6GB, 13B ~10GB, 70B ~44GB (4-bit quantized).
OLLAMA_CPU_LIMIT=4.0
OLLAMA_MEMORY_LIMIT=16G

# Number of GPUs to pass through. Use "all" or a specific count.
OLLAMA_GPU_COUNT=all

# Subdomain for SWAG reverse proxy.
# Result: https://ollama.yourdomain.com
OLLAMA_SUBDOMAIN=ollama

# ── Open WebUI ─────────────────────────────────────────────
# Image version tag.
OPEN_WEBUI_VERSION=main

# Host port for the Open WebUI chat interface.
OPEN_WEBUI_PORT=3000

# Subdomain for SWAG reverse proxy.
# Result: https://chat.yourdomain.com
OPEN_WEBUI_SUBDOMAIN=chat
