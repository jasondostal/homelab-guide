# Monitoring Stack Environment Variables
# ======================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── System ─────────────────────────────────────────────────
TZ=America/Chicago

# ── Domain ─────────────────────────────────────────────────
# Base domain for SWAG reverse proxy routing.
DOMAIN=yourdomain.com

# ── Uptime Kuma ────────────────────────────────────────────
# Version tag for the Uptime Kuma image.
UPTIME_KUMA_VERSION=1

# Port exposed on the host for direct access.
UPTIME_KUMA_PORT=3001

# Subdomain for SWAG reverse proxy.
# Result: https://status.yourdomain.com
UPTIME_KUMA_SUBDOMAIN=status

# ── Healthchecks.io Ping URLs ─────────────────────────────
# Optional: Use healthchecks.io to monitor the monitor itself.
# Create a check at https://healthchecks.io and paste the ping URL.
# The backup script and cron jobs use these to report status.
#
# Uptime Kuma self-check (is the monitoring stack healthy?)
HC_PING_MONITORING=https://hc-ping.com/YOUR-UUID-HERE

# General homelab heartbeat (cron pings this every 5 minutes)
HC_PING_HEARTBEAT=https://hc-ping.com/YOUR-UUID-HERE
