# Core Stack Environment Variables
# =================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Timezone ───────────────────────────────────────────────
# Use your system timezone (e.g., America/New_York, Europe/London)
TZ=America/Chicago

# ── Domain ─────────────────────────────────────────────────
# Your base domain for reverse proxy routing.
# Portainer will be accessible at portainer.yourdomain.com
DOMAIN=yourdomain.com

# ── Portainer ──────────────────────────────────────────────
# Version tag for portainer/portainer-ce image.
# Pin to a specific version to avoid surprise upgrades.
PORTAINER_VERSION=2.21

# Port exposed on the host for direct access (before SWAG is set up).
# Once SWAG is running, you can remove the ports section from compose.
PORTAINER_PORT=9443

# Subdomain used by SWAG reverse proxy.
# Result: https://portainer.yourdomain.com
PORTAINER_SUBDOMAIN=portainer
