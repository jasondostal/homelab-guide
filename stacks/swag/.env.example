# SWAG Reverse Proxy Environment Variables
# =========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── System ─────────────────────────────────────────────────
# User/group IDs for file permissions inside the container.
# Run `id` on your host to find your UID/GID.
PUID=1000
PGID=1000
TZ=America/Chicago

# ── Domain Configuration ───────────────────────────────────
# Your registered domain name (e.g., example.com)
DOMAIN=yourdomain.com

# Subdomains to include in the TLS certificate.
# Use "wildcard" for a *.yourdomain.com cert (recommended).
# Or list specific subdomains: portainer,grafana,ollama
SUBDOMAINS=wildcard

# ── Let's Encrypt ─────────────────────────────────────────
# Email for certificate registration and renewal notices.
LETSENCRYPT_EMAIL=you@yourdomain.com

# Validation method: "dns" or "http"
# DNS validation is required for wildcard certs.
# HTTP validation requires ports 80/443 to be publicly reachable.
VALIDATION=dns

# DNS provider plugin name. Must match your domain registrar.
# Common options: cloudflare, route53, digitalocean, duckdns, namecheap
# Full list: https://docs.linuxserver.io/images/docker-swag/#dns-plugins
DNSPLUGIN=cloudflare

# Set to "true" while testing to use Let's Encrypt staging servers.
# Staging certs aren't trusted by browsers but don't count against
# rate limits. Switch to "false" once everything works.
STAGING=false

# ── SWAG Image ─────────────────────────────────────────────
# Pin to a specific version tag for reproducible deployments.
# Use "latest" only for initial testing.
SWAG_VERSION=latest
