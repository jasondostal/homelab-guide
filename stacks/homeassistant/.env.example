# Home Assistant Stack Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── General ──────────────────────────────────────────────────
# Timezone (e.g., America/New_York, Europe/London)
TZ=America/Chicago

# ── Home Assistant ───────────────────────────────────────────
# Image version tag. "stable" tracks the latest stable release.
# Pin to a specific version (e.g., 2024.12) for predictable upgrades.
# Home Assistant releases monthly — check release notes before upgrading.
HA_VERSION=stable

# Resource limits. Increase memory if you have many integrations
# or a large automation set.
HA_CPU_LIMIT=2.0
HA_MEM_LIMIT=1G

# ── USB Device Passthrough (Zigbee/Z-Wave) ───────────────────
# Path to your Zigbee or Z-Wave USB coordinator.
# Find it with: ls -la /dev/serial/by-id/
#
# ALWAYS use the /dev/serial/by-id/ path — not /dev/ttyUSB0.
# The ttyUSB numbers can change between reboots.
#
# Examples:
#   Sonoff ZBDongle-E: /dev/serial/by-id/usb-ITEAD_SONOFF_Zigbee_3.0_...-if00
#   Sonoff ZBDongle-P: /dev/serial/by-id/usb-ITead_Sonoff_Zigbee_3.0_...-if00
#   Zooz Z-Wave 800:   /dev/serial/by-id/usb-Silicon_Labs_...-if00
ZIGBEE_DEVICE=/dev/serial/by-id/usb-ITEAD_SONOFF_Zigbee_your-device-id-here
